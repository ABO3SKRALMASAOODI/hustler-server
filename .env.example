# docker-compose dev env — copy to .env
# Postgres/MinIO creds are baked into docker-compose.yml; these are the
# externally-provided secrets.

# LLM (OpenAI-compatible). Leave OPENAI_API_KEY empty to disable the agent,
# or point OPENAI_BASE_URL at scripts/fake_llm.py for keyless testing.
OPENAI_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
OPENAI_API_KEY=
AGENT_MODEL=qwen-plus
VISION_MODEL=qwen-vl-plus

# Transcription size/speed tradeoff for local dev
WHISPER_MODEL=tiny

# AI sound-effect generation (ElevenLabs). Empty = the generate_sfx tool is
# hidden and the concierge won't offer custom sounds (the built-in CC0 pack
# still works). Set on the WORKER; the backend concierge only needs it to
# advertise the capability truthfully.
ELEVENLABS_API_KEY=
# SFX_PRICE_USD=0.08   # keep in sync with your ElevenLabs per-generation price

# AI video generation (fal.ai aggregator). Empty = the generate_video tool is
# hidden and the concierge keeps saying moving-video generation isn't available.
# Model is chosen entirely by env, like IMAGE_GEN_MODEL. Set FAL_KEY on the
# WORKER (backend concierge only reads it to advertise the capability).
FAL_KEY=
# VIDEO_GEN_MODEL=fal-ai/kling-video/v2.5-turbo/pro/image-to-video
# VIDEO_BASE_PRICE_USD=0.35   # first VIDEO_BASE_SECONDS seconds
# VIDEO_BASE_SECONDS=5
# VIDEO_PRICE_USD_PER_SEC=0.07  # keep ALL THREE synced to the fal model page
