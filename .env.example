# docker-compose dev env — copy to .env
# Postgres/MinIO creds are baked into docker-compose.yml; these are the
# externally-provided secrets.

# LLM (OpenAI-compatible). Leave OPENAI_API_KEY empty to disable the agent,
# or point OPENAI_BASE_URL at scripts/fake_llm.py for keyless testing.
OPENAI_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
OPENAI_API_KEY=
AGENT_MODEL=qwen-plus
VISION_MODEL=qwen-vl-plus

# Transcription size/speed tradeoff for local dev
WHISPER_MODEL=tiny
